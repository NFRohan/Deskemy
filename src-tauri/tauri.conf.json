{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deskemy",
  "version": "1.0.0",
  "identifier": "com.spooksy.deskemy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Deskemy",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Spooksy",
    "copyright": "© 2026 Nayeem Fardin",
    "category": "Education",
    "shortDescription": "Offline player for your downloaded video courses.",
    "longDescription": "Deskemy turns folders of downloaded video courses into an offline, Udemy-style library — resume, chapters, subtitles, bookmarks, tags, full-text and subtitle search, career tracks, and a study-stats dashboard. Playback uses your own installed mpv; nothing leaves your machine.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "licenseFile": "../LICENSE",
    "resources": {
      "vendor/libmpv-2.dll": "libmpv-2.dll",
      "licenses/GPL-2.0.txt": "licenses/GPL-2.0.txt",
      "licenses/libmpv-NOTICE.txt": "licenses/libmpv-NOTICE.txt"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  }
}
